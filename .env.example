NODE_ENV=development
DATABASE_URL=postgresql://perf:perf@localhost:5432/perf_tracker?schema=public

# Postgres (docker-compose reads these)
POSTGRES_USER=perf
POSTGRES_PASSWORD=perf
POSTGRES_DB=perf_tracker

# API
API_PORT=3000
WEB_ORIGIN=http://localhost:5173
SESSION_SECRET=dev-only-change-me-please-use-a-long-random-string-in-prod
SESSION_TTL_DAYS=7
COOKIE_SECURE=false

# Mail (Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=no-reply@perf-tracker.local

# Storage (local disk; optional MinIO)
STORAGE_DRIVER=disk
STORAGE_DIR=./.storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=perf-tracker
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Seed admin
ADMIN_EMAIL=admin@perf-tracker.local
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin User
